---
import MainLayout from "./MainLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PageHeader from "../components/PageHeader.astro";
import CodeCopyButton from "../components/CodeCopyButton.astro";
import ImageViewer from "../components/ImageViewer.astro";
import PrevNextNav from "../components/PrevNextNav.astro";
import type { CollectionEntry } from "astro:content";

interface PostLink {
  title: string;
  href: string;
}

interface Props {
  post: CollectionEntry<"notes">;
  navData: any;
  prev?: PostLink;
  next?: PostLink;
  googleAnalyticsId?: string;
  googleAdsenseClient?: string;
  productionHostname?: string;
  siteName?: string; // For meta description fallback
}

const {
  post,
  navData,
  prev,
  next,
  googleAnalyticsId,
  googleAdsenseClient,
  productionHostname,
  siteName,
} = Astro.props;
const { title, pubDate, description, sub_title, featuredImgPath: rawFeaturedImg } = post.data;
const _resolvedImg = rawFeaturedImg
  ? (typeof rawFeaturedImg === 'string' ? rawFeaturedImg : rawFeaturedImg.src)
  : undefined;
// /@fs/... = Vite dev-server internal path; ./ or ../ = relative path that can't be a URL
const featuredImgPath =
  _resolvedImg && !_resolvedImg.startsWith('/@') && !_resolvedImg.startsWith('.')
    ? _resolvedImg
    : undefined;

// Extract category from post ID
const category = post.id.split("/")[0];

// Use sub_title as fallback description
const metaDescription =
  description ||
  sub_title ||
  (siteName ? `Read ${title} on ${siteName}` : `Read ${title}`);

// Structured Data
const breadcrumbItems = [
  { name: "Home", item: Astro.site?.toString() || "" },
  { name: "Blog", item: new URL("/blog", Astro.site).toString() },
  { name: category, item: new URL(`/blog/${category}`, Astro.site).toString() },
  { name: title, item: new URL(Astro.url.pathname, Astro.site).toString() },
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": new URL(Astro.url.pathname, Astro.site).toString(),
      headline: title,
      description: metaDescription,
      image: featuredImgPath
        ? new URL(featuredImgPath, Astro.site).toString()
        : undefined,
      datePublished: pubDate,
      author: {
        "@type": "Person",
        name: "Bhavani Ravi",
        url: "https://bhavaniravi.com",
      },
      publisher: {
        "@type": "Organization",
        name: siteName || "Bhavani Ravi",
        logo: {
          "@type": "ImageObject",
          url: new URL("/favicon/favicon-32x32.png", Astro.site).toString(),
        },
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": new URL(Astro.url.pathname, Astro.site).toString(),
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbItems.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.name,
        item: item.item,
      })),
    },
  ],
};
---

<MainLayout
  title={title}
  description={metaDescription}
  image={featuredImgPath || undefined}
  navData={navData}
  googleAnalyticsId={googleAnalyticsId}
  googleAdsenseClient={googleAdsenseClient}
  productionHostname={productionHostname}
  schema={structuredData}
>
  <article class="max-w-4xl mx-auto px-6 lg:px-8 py-8 lg:py-12">
    <Breadcrumbs category={category} title={title} />

    <PageHeader
      title={title}
      subtitle={sub_title || undefined}
      date={pubDate}
    />

    <div class="prose prose-lg dark:prose-dark max-w-none">
      <slot />
    </div>
  </article>

  <PrevNextNav prev={prev} next={next} />

  <CodeCopyButton />
  <ImageViewer />
</MainLayout>
